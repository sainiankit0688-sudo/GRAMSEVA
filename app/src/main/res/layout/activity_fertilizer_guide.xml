<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="@color/primary"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:tint="@color/on_primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="8dp"
            android:text="🌿 Fertilizer Guide"
            android:textColor="@color/on_primary"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/primary"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌿 FERTILIZER GUIDE"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Right Fertilizer, Right Dose, Right Time\nFor Better Crop, Higher Yield &amp; More Profit"
                    android:textSize="12sp"
                    android:textColor="@color/on_primary"
                    android:gravity="center"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Card 1: Fertilizer Categories -->
            <LinearLayout android:id="@+id/card_fert_categories" style="@style/ExamCard">
                <TextView style="@style/ExamBadge" android:text="1" android:backgroundTint="#2E7D32" />
                <LinearLayout style="@style/ExamCardContent">
                    <TextView style="@style/ExamCardTitle" android:text="🌿 Fertilizer Categories" />
                    <TextView style="@style/ExamCardSub" android:text="Macro • Secondary • Micro • Bio • Organic" />
                </LinearLayout>
                <TextView style="@style/ExamArrow" />
            </LinearLayout>

            <!-- Card 2: Fertilizer List -->
            <LinearLayout android:id="@+id/card_fert_list" style="@style/ExamCard">
                <TextView style="@style/ExamBadge" android:text="2" android:backgroundTint="#1565C0" />
                <LinearLayout style="@style/ExamCardContent">
                    <TextView style="@style/ExamCardTitle" android:text="📋 Fertilizer List" />
                    <TextView style="@style/ExamCardSub" android:text="Urea • DAP • NPK • Potash • SSP • Zinc" />
                </LinearLayout>
                <TextView style="@style/ExamArrow" />
            </LinearLayout>

            <!-- Card 3: Nutrient Information -->
            <LinearLayout android:id="@+id/card_nutrient_info" style="@style/ExamCard">
                <TextView style="@style/ExamBadge" android:text="3" android:backgroundTint="#E65100" />
                <LinearLayout style="@style/ExamCardContent">
                    <TextView style="@style/ExamCardTitle" android:text="🔬 Nutrient Information" />
                    <TextView style="@style/ExamCardSub" android:text="Content • Benefits • Deficiency • Excess" />
                </LinearLayout>
                <TextView style="@style/ExamArrow" />
            </LinearLayout>

            <!-- Card 4: Crop Wise Fertilizer Guide -->
            <LinearLayout android:id="@+id/card_crop_wise" style="@style/ExamCard">
                <TextView style="@style/ExamBadge" android:text="4" android:backgroundTint="#6A1B9A" />
                <LinearLayout style="@style/ExamCardContent">
                    <TextView style="@style/ExamCardTitle" android:text="🌾 Crop Wise Fertilizer Guide" />
                    <TextView style="@style/ExamCardSub" android:text="Crop • Soil • Stage • Dose • Method" />
                </LinearLayout>
                <TextView style="@style/ExamArrow" />
            </LinearLayout>

            <!-- Card 5: Fertilizer Schedule -->
            <LinearLayout android:id="@+id/card_fert_schedule" style="@style/ExamCard">
                <TextView style="@style/ExamBadge" android:text="5" android:backgroundTint="#00695C" />
                <LinearLayout style="@style/ExamCardContent">
                    <TextView style="@style/ExamCardTitle" android:text="📅 Fertilizer Schedule" />
                    <TextView style="@style/ExamCardSub" android:text="Monthly • Growth Stage • Irrigation Based" />
                </LinearLayout>
                <TextView style="@style/ExamArrow" />
            </LinearLayout>

            <!-- Card 6: Fertilizer Calculator -->
            <LinearLayout android:id="@+id/card_fert_calculator" style="@style/ExamCard">
                <TextView style="@style/ExamBadge" android:text="6" android:backgroundTint="#F57F17" />
                <LinearLayout style="@style/ExamCardContent">
                    <TextView style="@style/ExamCardTitle" android:text="🧮 Fertilizer Calculator" />
                    <TextView style="@style/ExamCardSub" android:text="Crop • Area • Quantity • Cost Estimation" />
                </LinearLayout>
                <TextView style="@style/ExamArrow" />
            </LinearLayout>

            <!-- Card 7: Safe Use -->
            <LinearLayout android:id="@+id/card_safe_use" style="@style/ExamCard">
                <TextView style="@style/ExamBadge" android:text="7" android:backgroundTint="#C62828" />
                <LinearLayout style="@style/ExamCardContent">
                    <TextView style="@style/ExamCardTitle" android:text="🛡️ Safe Use &amp; Precautions" />
                    <TextView style="@style/ExamCardSub" android:text="Dose • Time • Method • Storage • Safety" />
                </LinearLayout>
                <TextView style="@style/ExamArrow" />
            </LinearLayout>

            <!-- How to Choose Steps -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔄 How to Choose &amp; Apply Fertilizer"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/on_surface"
                android:paddingTop="8dp"
                android:paddingBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="12dp"
                android:layout_marginBottom="8dp">

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="1️⃣  Know Your Soil — Test soil and know nutrient status"
                    android:textSize="13sp" android:textColor="@color/on_surface" android:paddingVertical="6dp" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="2️⃣  Know Your Crop — Select crop and understand its nutrient needs"
                    android:textSize="13sp" android:textColor="@color/on_surface" android:paddingVertical="6dp" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="3️⃣  Choose Right Fertilizer — Select as per crop, soil and growth stage"
                    android:textSize="13sp" android:textColor="@color/on_surface" android:paddingVertical="6dp" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="4️⃣  Apply Right Dose — Use recommended dose per acre/hectare"
                    android:textSize="13sp" android:textColor="@color/on_surface" android:paddingVertical="6dp" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="5️⃣  Apply Right Time — Apply at the correct time and growth stage"
                    android:textSize="13sp" android:textColor="@color/on_surface" android:paddingVertical="6dp" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="6️⃣  Apply Right Method — Use the correct method for maximum benefit"
                    android:textSize="13sp" android:textColor="@color/on_surface" android:paddingVertical="6dp" />
            </LinearLayout>

            <!-- Benefits -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/primary"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Benefits to Farmers"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✅ Better Crop Growth  ✅ Higher Yield\n✅ Save Cost  ✅ Improve Soil Health  ✅ More Profit"
                    android:textSize="13sp"
                    android:textColor="@color/on_primary"
                    android:gravity="center"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌱 Healthy Soil, Healthy Crop, Prosperous Farmer"
                    android:textSize="12sp"
                    android:textColor="@color/on_primary"
                    android:gravity="center"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
