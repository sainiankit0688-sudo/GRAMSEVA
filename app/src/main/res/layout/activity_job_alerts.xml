<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".JobAlertsActivity">

    <!-- Top App Bar -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="@color/surface"
        android:elevation="2dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_gutter"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btn_menu"
            android:layout_width="@dimen/touch_target"
            android:layout_height="@dimen/touch_target"
            android:background="?selectableItemBackgroundBorderless"
            android:contentDescription="Menu"
            android:padding="12dp"
            android:scaleType="center"
            android:src="@drawable/ic_menu" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:text="@string/app_title"
            android:textColor="@color/primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btn_notifications"
            android:layout_width="@dimen/touch_target"
            android:layout_height="@dimen/touch_target"
            android:background="?selectableItemBackgroundBorderless"
            android:contentDescription="Notifications"
            android:padding="12dp"
            android:scaleType="center"
            android:src="@drawable/ic_notifications" />
    </LinearLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottom_navigation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/top_bar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/spacing_stack_md">

            <!-- Hero Section -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/hero_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/spacing_gutter"
                android:layout_marginTop="@dimen/spacing_stack_md"
                app:cardBackgroundColor="@color/primary_container"
                app:cardCornerRadius="@dimen/radius_xl"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_stack_lg">

                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:contentDescription="Job Alerts"
                        android:importantForAccessibility="no"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_work"
                        app:tint="@color/on_primary_container" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_stack_md"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/job_alerts"
                        android:textColor="@color/on_primary_container"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="280dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_stack_sm"
                        android:gravity="center"
                        android:lineSpacingExtra="4dp"
                        android:text="@string/job_alerts_desc"
                        android:textColor="@color/on_primary_container"
                        android:textSize="16sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Toggle Section -->
            <LinearLayout
                android:id="@+id/toggle_container"
                android:layout_width="match_parent"
                android:layout_height="@dimen/touch_target"
                android:layout_marginHorizontal="@dimen/spacing_gutter"
                android:layout_marginTop="@dimen/spacing_stack_md"
                android:background="@drawable/bg_outline_button"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/toggle_govt"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_primary_button"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:text="@string/govt_jobs"
                    android:textColor="@color/on_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/toggle_private"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:text="@string/private_jobs"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Get Notified Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_get_notified"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/touch_target"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/spacing_stack_md"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="0dp"
                android:paddingHorizontal="@dimen/spacing_stack_lg"
                android:text="@string/get_notified"
                android:textAllCaps="false"
                android:textColor="@color/on_secondary"
                android:textSize="14sp"
                android:textStyle="bold"
                app:backgroundTint="@color/secondary"
                app:cornerRadius="24dp"
                app:icon="@drawable/ic_notifications"
                app:iconGravity="textStart"
                app:iconTint="@color/on_secondary" />

            <!-- Section Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_gutter"
                android:layout_marginTop="@dimen/spacing_stack_md"
                android:fontFamily="sans-serif-medium"
                android:text="@string/recent_openings"
                android:textColor="@color/on_surface"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- Job Cards Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/spacing_gutter"
                android:layout_marginTop="@dimen/spacing_stack_sm"
                android:orientation="horizontal">

                <!-- Job Card 1: Gram Panchayat Assistant -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardBackgroundColor="@color/surface_container_lowest"
                    app:cardCornerRadius="@dimen/radius_lg"
                    app:cardElevation="1dp"
                    app:strokeColor="@color/outline_variant"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_stack_md">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@color/primary_fixed_dim"
                                android:contentDescription="Category"
                                android:padding="8dp"
                                android:scaleType="center"
                                android:src="@drawable/ic_work"
                                app:tint="@color/on_surface" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="22dp"
                                android:layout_gravity="end"
                                android:background="@color/primary_container"
                                android:fontFamily="sans-serif-medium"
                                android:gravity="center"
                                android:paddingHorizontal="8dp"
                                android:text="@string/active"
                                android:textColor="@color/on_primary_container"
                                android:textSize="10sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_stack_sm"
                            android:fontFamily="sans-serif-medium"
                            android:lineSpacingExtra="1dp"
                            android:text="@string/job_gram_panchayat"
                            android:textColor="@color/on_surface"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/job_gram_panchayat_org"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="12sp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:contentDescription="Location"
                                android:scaleType="fitCenter"
                                android:src="@drawable/ic_home"
                                app:tint="@color/on_surface_variant" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="@string/job_gram_panchayat_loc"
                                android:textColor="@color/on_surface_variant"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:contentDescription="Salary"
                                android:scaleType="fitCenter"
                                android:src="@drawable/ic_work"
                                app:tint="@color/on_surface_variant" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="@string/job_gram_panchayat_salary"
                                android:textColor="@color/on_surface_variant"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <Button
                            android:layout_width="match_parent"
                            android:layout_height="32dp"
                            android:layout_marginTop="@dimen/spacing_stack_sm"
                            android:background="@drawable/bg_primary_button"
                            android:drawableStart="@drawable/ic_work"
                            android:fontFamily="sans-serif-medium"
                            android:gravity="center"
                            android:minHeight="0dp"
                            android:paddingVertical="0dp"
                            android:text="@string/apply_now"
                            android:textAllCaps="false"
                            android:textColor="@color/on_primary"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Job Card 2: ASHA Worker -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardBackgroundColor="@color/surface_container_lowest"
                    app:cardCornerRadius="@dimen/radius_lg"
                    app:cardElevation="1dp"
                    app:strokeColor="@color/outline_variant"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_stack_md">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@color/secondary_container"
                                android:contentDescription="Category"
                                android:padding="8dp"
                                android:scaleType="center"
                                android:src="@drawable/ic_work"
                                app:tint="@color/on_secondary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="22dp"
                                android:layout_gravity="end"
                                android:background="@color/tertiary_container"
                                android:fontFamily="sans-serif-medium"
                                android:gravity="center"
                                android:paddingHorizontal="8dp"
                                android:text="@string/tag_new"
                                android:textColor="@color/on_tertiary"
                                android:textSize="10sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_stack_sm"
                            android:fontFamily="sans-serif-medium"
                            android:lineSpacingExtra="1dp"
                            android:text="@string/job_asha"
                            android:textColor="@color/on_surface"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/job_asha_org"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="12sp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:contentDescription="Location"
                                android:scaleType="fitCenter"
                                android:src="@drawable/ic_home"
                                app:tint="@color/on_surface_variant" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="@string/job_asha_loc"
                                android:textColor="@color/on_surface_variant"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:contentDescription="Salary"
                                android:scaleType="fitCenter"
                                android:src="@drawable/ic_work"
                                app:tint="@color/on_surface_variant" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="@string/job_asha_salary"
                                android:textColor="@color/on_surface_variant"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <Button
                            android:layout_width="match_parent"
                            android:layout_height="32dp"
                            android:layout_marginTop="@dimen/spacing_stack_sm"
                            android:background="@drawable/bg_primary_button"
                            android:drawableStart="@drawable/ic_work"
                            android:fontFamily="sans-serif-medium"
                            android:gravity="center"
                            android:minHeight="0dp"
                            android:paddingVertical="0dp"
                            android:text="@string/apply_now"
                            android:textAllCaps="false"
                            android:textColor="@color/on_primary"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Job Cards Row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/spacing_gutter"
                android:layout_marginTop="@dimen/spacing_stack_sm"
                android:orientation="horizontal">

                <!-- Job Card 3: Village Security Guard -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardBackgroundColor="@color/surface_container_lowest"
                    app:cardCornerRadius="@dimen/radius_lg"
                    app:cardElevation="1dp"
                    app:strokeColor="@color/outline_variant"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_stack_md">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@color/primary_fixed_dim"
                                android:contentDescription="Category"
                                android:padding="8dp"
                                android:scaleType="center"
                                android:src="@drawable/ic_work"
                                app:tint="@color/on_surface" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="22dp"
                                android:layout_gravity="end"
                                android:background="@color/error_container"
                                android:fontFamily="sans-serif-medium"
                                android:gravity="center"
                                android:paddingHorizontal="8dp"
                                android:text="@string/tag_closes_soon"
                                android:textColor="@color/on_error_container"
                                android:textSize="10sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_stack_sm"
                            android:fontFamily="sans-serif-medium"
                            android:lineSpacingExtra="1dp"
                            android:text="@string/job_security"
                            android:textColor="@color/on_surface"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/job_security_org"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="12sp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:contentDescription="Location"
                                android:scaleType="fitCenter"
                                android:src="@drawable/ic_home"
                                app:tint="@color/on_surface_variant" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="@string/job_security_loc"
                                android:textColor="@color/on_surface_variant"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:contentDescription="Salary"
                                android:scaleType="fitCenter"
                                android:src="@drawable/ic_work"
                                app:tint="@color/on_surface_variant" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="@string/job_security_salary"
                                android:textColor="@color/on_surface_variant"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <Button
                            android:layout_width="match_parent"
                            android:layout_height="32dp"
                            android:layout_marginTop="@dimen/spacing_stack_sm"
                            android:background="@drawable/bg_primary_button"
                            android:drawableStart="@drawable/ic_work"
                            android:fontFamily="sans-serif-medium"
                            android:gravity="center"
                            android:minHeight="0dp"
                            android:paddingVertical="0dp"
                            android:text="@string/apply_now"
                            android:textAllCaps="false"
                            android:textColor="@color/on_primary"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Job Card 4: Bank Mitra -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardBackgroundColor="@color/surface_container_lowest"
                    app:cardCornerRadius="@dimen/radius_lg"
                    app:cardElevation="1dp"
                    app:strokeColor="@color/outline_variant"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_stack_md">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@color/secondary_container"
                                android:contentDescription="Category"
                                android:padding="8dp"
                                android:scaleType="center"
                                android:src="@drawable/ic_work"
                                app:tint="@color/on_secondary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="22dp"
                                android:layout_gravity="end"
                                android:background="@color/primary_container"
                                android:fontFamily="sans-serif-medium"
                                android:gravity="center"
                                android:paddingHorizontal="8dp"
                                android:text="@string/active"
                                android:textColor="@color/on_primary_container"
                                android:textSize="10sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_stack_sm"
                            android:fontFamily="sans-serif-medium"
                            android:lineSpacingExtra="1dp"
                            android:text="@string/job_bank_mitra"
                            android:textColor="@color/on_surface"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/job_bank_mitra_org"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="12sp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:contentDescription="Location"
                                android:scaleType="fitCenter"
                                android:src="@drawable/ic_home"
                                app:tint="@color/on_surface_variant" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="@string/job_bank_mitra_loc"
                                android:textColor="@color/on_surface_variant"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:contentDescription="Salary"
                                android:scaleType="fitCenter"
                                android:src="@drawable/ic_work"
                                app:tint="@color/on_surface_variant" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="@string/job_bank_mitra_salary"
                                android:textColor="@color/on_surface_variant"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <Button
                            android:layout_width="match_parent"
                            android:layout_height="32dp"
                            android:layout_marginTop="@dimen/spacing_stack_sm"
                            android:background="@drawable/bg_primary_button"
                            android:drawableStart="@drawable/ic_work"
                            android:fontFamily="sans-serif-medium"
                            android:gravity="center"
                            android:minHeight="0dp"
                            android:paddingVertical="0dp"
                            android:text="@string/apply_now"
                            android:textAllCaps="false"
                            android:textColor="@color/on_primary"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Guidance Card (spanning 2 columns) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/guidance_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/spacing_gutter"
                android:layout_marginTop="@dimen/spacing_stack_md"
                app:cardBackgroundColor="@color/surface_container_high"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_stack_md">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/need_guidance"
                            android:textColor="@color/on_surface"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:lineSpacingExtra="2dp"
                            android:text="@string/guidance_text"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="?selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingLeft="@dimen/spacing_stack_md"
                        android:paddingVertical="@dimen/spacing_stack_sm">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/watch_videos"
                            android:textColor="@color/primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginStart="4dp"
                            android:contentDescription="Watch"
                            android:src="@drawable/ic_arrow_forward"
                            app:tint="@color/primary" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation Bar -->
    <LinearLayout
        android:id="@+id/bottom_navigation"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:background="@color/surface"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:id="@+id/nav_home"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Home"
                android:src="@drawable/ic_home" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/home"
                android:textColor="@color/on_surface_variant"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_complaints"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Complaints"
                android:src="@drawable/ic_report"
                app:tint="@color/on_surface_variant" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/nav_complaints"
                android:textColor="@color/on_surface_variant"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_services"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/primary_container"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Services"
                android:src="@drawable/ic_apps"
                app:tint="@color/on_primary_container" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/services"
                android:textColor="@color/on_primary_container"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_profile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Profile"
                android:src="@drawable/ic_person" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/profile"
                android:textColor="@color/on_surface_variant"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
