    <string name="about_app_text">Gram Seva v1.0\nEmpowering villages through digital connection.</string>
    <string name="about_version">Version 1.0.0</string>
    <string name="about_desc">Gram Seva ek rural service app hai jo gaon ke logon ko sarkari yojnaon, shiksha, swasthya, kheti aur anya mahatvapurna sevayon ki jankari pradan karti hai. Hamara uddeshya digital madhyam se gaon tak sahi aur upyogi jankari pahunchana hai.</string>
    <string name="about_features_title">Main Features</string>
    <string name="about_features">🌾 Agriculture Information\n🎓 Education Schemes\n🏥 Health Services\n🏠 Housing Schemes\n🚨 Emergency Contacts\n🔔 Notifications</string>
    <string name="about_mission_title">Mission</string>
    <string name="about_mission">Gaon ke logon tak sahi aur upyogi jankari\ndigital madhyam se pahunchana.</string>
    <string name="about_developer">Developer: Ankit Kumar</string>
    <string name="about_disclaimer_title">Disclaimer</string>
    <string name="about_disclaimer">Gram Seva ek informational platform hai jo Government Schemes, Agriculture, Health, Housing aur Education se sambandhit jankari pradan karta hai.\n\nHum jankari ko satik aur updated rakhne ka prayas karte hain, lekin kisi bhi yojna ya seva ki adhikarik aur naveenatam jankari ke liye sambandhit sarkari website ya vibhag se pushti avashya karein.\n\nGram Seva kisi bhi sarkari sanstha ya vibhag ka adhikarik application nahi hai.</string>
    <string name="privacy_coming_soon">Privacy Policy coming soon</string>

    <!-- Privacy Policy -->
    <string name="privacy_last_updated">Last Updated: June 2026</string>
    <string name="privacy_intro">Gram Seva respects your privacy. This policy explains what information the app collects and how it is used.</string>

    <string name="privacy_section1_title">1. Information We Collect</string>
    <string name="privacy_section1_body">We may collect the following information:\n\n• Name\n• Mobile Number\n• Email Address\n• Village / District Information</string>

    <string name="privacy_section2_title">2. How We Use Information</string>
    <string name="privacy_section2_body">Your information is used for:\n\n• Profile management\n• Providing personalized services\n• Sending notifications\n• Improving app experience</string>

    <string name="privacy_section3_title">3. Data Security</string>
    <string name="privacy_section3_body">We strive to keep your information secure. Data may be stored on Firebase and other trusted services.</string>

    <string name="privacy_section4_title">4. Third-Party Services</string>
    <string name="privacy_section4_body">The app may use Firebase, Google Notifications, and other trusted services.</string>

    <string name="privacy_section5_title">5. Government Information</string>
    <string name="privacy_section5_body">Gram Seva provides information about government schemes and services. For official and latest information, please refer to the respective government website.</string>

    <string name="privacy_section6_title">6. User Rights</string>
    <string name="privacy_section6_body">Users can update or delete their profile information.</string>

    <string name="privacy_section7_title">7. Contact</string>
    <string name="privacy_section7_body">For any privacy-related questions, please contact the developer:\n\nDeveloper: Ankit Kumar</string>

    <string name="privacy_section8_title">8. Disclaimer</string>
    <string name="privacy_section8_body">Gram Seva is not an official application of any government agency or department.</string>

